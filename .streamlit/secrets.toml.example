DAILY_PROMPT_LIMIT = 20
ROUTER_MODEL = "llama3.2-3b"
MAIN_MODEL = "llama3.2-3b"
CORTEX_SEARCH_SERVICE = "PAPER_SEARCH"

[connections.snowflake]
account = "YOUR_ACCOUNT_IDENTIFIER"
user = "YOUR_APP_USER"
